# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
# conda env lives outside the repo — nothing to ignore here

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Smoke test — generated artifacts (reproducible by following the README) ───
# Data files generated during testing — recreated by running the setup commands
smoke_test/data/
smoke_test/shards/
smoke_test/output/

# Encoded knowledge base — large binary files (~500 MB), regenerated by Step 7
smoke_test/kb/my_knowledge_dataset/
smoke_test/kb/my_knowledge_dataset_hnsw_index.faiss

# The raw passage files ARE small and useful as examples — keep them
# smoke_test/kb/passages.tsv  ← intentionally NOT ignored

# ── Test run cache (original repo artifacts, not needed in git) ───────────────
test_run/cache/

# ── Model checkpoints and training outputs ────────────────────────────────────
*.ckpt
*.pt
*.bin
# safetensors model files are large — not for git
*.safetensors
# Exception: keep any tiny demo weights if you add them later
# !some_small_demo.safetensors

# ── FAISS indexes ─────────────────────────────────────────────────────────────
*.faiss
# Exception: if you ever commit a tiny pre-built demo index:
# !test_run/dummy-kb/*.faiss

# ── HuggingFace / Ray cache (always outside the repo) ─────────────────────────
# ~/.cache/huggingface/  ← not in repo, nothing to ignore
# /tmp/ray/              ← not in repo, nothing to ignore

# ── Logs and experiment outputs ───────────────────────────────────────────────
wandb/
lightning_logs/
*.log
runs/

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
